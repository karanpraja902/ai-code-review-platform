# SMTP Configuration for Email Service
# Gmail SMTP Configuration (recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Alternative SMTP providers:
# For Outlook/Hotmail:
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_SECURE=false

# For Yahoo:
# SMTP_HOST=smtp.mail.yahoo.com
# SMTP_PORT=587
# SMTP_SECURE=false

# Email Rate Limiting
MAIL_RATE_LIMIT=10

# Other environment variables (add your existing ones here)
# AI_CODE_REVIEW_DB=your-mongodb-connection-string
# REDIS_URL=your-redis-url
# GOOGLE_API_KEY=your-google-api-key
# E2B_API_KEY=your-e2b-api-key
# E2B_SANDBOX_TEMPLATE=your-sandbox-template-id
# API_BASE_URL=http://localhost:3001
# SANDBOX_AUTH_TOKEN=generate-a-long-random-value-or-let-the-api-create-one
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=us-east-1
# AWS_BEDROCK_API_KEY=optional-bedrock-bearer-key
# GOOGLE_CREDENTIALS_JSON_BASE64=optional-base64-vertex-service-account-json
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# GITHUB_TOKEN=your-github-token
# GITHUB_APP_ID=your-github-app-id
# GITHUB_PRIVATE_KEY_BASE64=your-github-private-key-base64
# GITHUB_WEBHOOK_SECRET=your-github-webhook-secret
# FRONTEND_URL=http://localhost:3000
