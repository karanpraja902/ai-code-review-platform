{
  "name": "ai-code-review-platform",
  "description": "AI Code Review Platform platform monorepo for AI-powered repository and pull request analysis.",
  "author": "Karan Prajapat <karanpraja902@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/karanpraja902/ai-code-review-platform.git"
  },
  "homepage": "https://github.com/karanpraja902/ai-code-review-platform#readme",
  "bugs": {
    "url": "https://github.com/karanpraja902/ai-code-review-platform/issues"
  },
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "workspaces": ["apps/*", "packages/*"],
  "devDependencies": {
    "prettier": "^3.6.2",
    "turbo": "^2.5.5",
    "typescript": "5.8.3"
  },
  "pnpm": {
    "overrides": {
      "strip-ansi": "6.0.1"
    }
  },
  "packageManager": "pnpm@8.15.2",
  "engines": {
    "node": ">=18"
  }
}
